# MongoDB connection string
DB_URL=mongodb://127.0.0.1:27017/tour

# Server
PORT=5000
NODE_ENV=development

# JWT — must MATCH the deployed API's secret so locally-minted tokens are
# accepted by the deployed data endpoints (/bookings, /wishlists).
JWT_SECRET=replace-with-shared-secret
JWT_EXPIRES_IN=7d

# Allowed CORS origins (comma-separated). The Next.js proxy calls server-side,
# but this allows direct browser calls during development.
CORS_ORIGIN=http://localhost:3000
